# Copy this file to .env.local and fill in the values.
# Do NOT commit .env.local to version control.

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://blackroadquantum.shop

# ── Stripe ───────────────────────────────────────────────────────────────────
# From https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── NextAuth / OAuth ─────────────────────────────────────────────────────────
# Generate a secret: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://blackroadquantum.shop

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Contributor access control ────────────────────────────────────────────────
# API key that must be sent as x-blackroad-api-key header on protected endpoints
BLACKROAD_API_KEY=

# Comma-separated list of GitHub account emails allowed to sign in
# Leave blank to allow any authenticated user
ALLOWED_CONTRIBUTOR_EMAILS=
